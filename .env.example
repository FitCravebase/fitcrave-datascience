# ============================================
# FitCrave AI Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitcrave
MONGODB_DB_NAME=fitcrave

# --- Firebase ---
# Path to your Firebase service account JSON file
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# --- External APIs ---
# CalorieNinja API (fallback nutrition data)
CALORIENINJA_API_KEY=your_calorieninja_api_key_here

# --- App Config ---
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# --- Notification Scheduling ---
# Cron expression for daily briefing (default: 7:00 AM IST)
DAILY_BRIEFING_CRON=0 7 * * *
# Cron expression for weekly review (default: Sunday 8:00 PM IST)
WEEKLY_REVIEW_CRON=0 20 * * 0
